# ═══════════════════════════════════════════════════════════════════════════════
# Makefile.dev · Developer Environment & Local Utilities
# ═══════════════════════════════════════════════════════════════════════════════
# This fragment contains everything an engineer needs to bootstrap, refresh, or
# tear down the local development environment quickly.

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Shared Configuration                                                        │
# └─────────────────────────────────────────────────────────────────────────────┘

include Makefile.common

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Target Declarations                                                         │
# └─────────────────────────────────────────────────────────────────────────────┘

.PHONY: dev dev-setup dev-verify dev-clean dev-clean-all dev-rebuild \
    setup install clean clean-all \
    venv venv-activate venv-run \
    doctor

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Environment Provisioning                                                   │
# └─────────────────────────────────────────────────────────────────────────────┘

# ✨ TARGET: dev
#   • What: Installs all dependencies and sets up the development environment.
dev:
	@echo "🔧 Setting up M365 AI Workforce development environment..."
	@echo ""
	@echo "Step 1/3: Installing Python dependencies..."
	@if [ -f "requirements.txt" ]; then \
		PY_VERSION=$$($(PY) --version 2>/dev/null | cut -d' ' -f2 | cut -d'.' -f1,2); \
		echo "  Detected Python version: $$PY_VERSION"; \
		if [ -d "$(VENV_DIR)" ]; then \
			echo "  Removing existing virtual environment ($(VENV_DIR))..."; \
			rm -rf "$(VENV_DIR)"; \
		fi; \
		echo "  Creating fresh Python virtual environment with $(PY)..."; \
		if $(PY) -m venv $(VENV_DIR) 2>&1; then \
			echo "  ✅ Venv created successfully"; \
		else \
			echo "  ⚠️  Failed to create venv"; \
			exit 0; \
		fi; \
		VENV_PY_PATH="$$(pwd)/$(VENV_DIR)/bin/python"; \
		if [ -x "$$VENV_PY_PATH" ]; then \
			echo "  Upgrading pip, wheel, setuptools..."; \
			$$VENV_PY_PATH -m pip install --upgrade pip wheel setuptools --quiet; \
			echo "  Installing from requirements.txt..."; \
			$$VENV_PY_PATH -m pip install -r requirements.txt --quiet || (echo "  ⚠️  Some Python dependencies failed to install" && exit 0); \
			echo "  ✅ Python dependencies installed"; \
		fi; \
	else \
		echo "  ℹ️  No requirements.txt found, skipping Python dependencies"; \
	fi
	@echo ""
	@echo "Step 2/3: Installing Node.js dependencies (if package.json exists)..."
	@if [ -f "package.json" ]; then \
		$(NPM) install --legacy-peer-deps || $(NPM) install; \
		echo "  ✅ Node.js dependencies installed"; \
	else \
		echo "  ℹ️  No package.json found, skipping Node.js dependencies"; \
	fi
	@echo ""
	@echo "Step 3/3: Setting up environment files..."
	@if [ ! -f "instances/sandbox.env" ] && [ -f "instances/sandbox.env.example" ]; then \
		cp instances/sandbox.env.example instances/sandbox.env; \
		echo "  ✅ Created sandbox.env from example"; \
		echo "  ⚠️  Please edit instances/sandbox.env with your credentials"; \
	else \
		echo "  ℹ️  sandbox.env already exists or example not found"; \
	fi
	@echo ""
	@echo "✅ Development environment ready!"
	@echo ""
	@echo "📋 Next steps:"
	@if [ -d "$(VENV_DIR)" ]; then \
		echo "  0. Activate Python virtual environment:"; \
		echo "     source $(VENV_DIR)/bin/activate"; \
		echo ""; \
	fi
	@echo "  1. Configure environment variables:"
	@echo "     Edit instances/sandbox.env with your Graph API credentials"
	@echo ""
	@echo "  2. Start the API:"
	@echo "     make serve-api"
	@echo ""
	@echo "  3. View dashboards:"
	@echo "     http://localhost:9000/api/agents/dashboard"

# 🚀 TARGET: dev-setup
dev-setup: dev
	@echo ""
	@echo "✅ Development setup complete!"

# ✅ TARGET: dev-verify
dev-verify:
	@echo "🔎 Verifying development environment..."
	@echo ""
	@echo "Checking Python..."
	@$(PY) --version || (echo "❌ Python not found" && exit 1)
	@echo "  ✅ Python: $$($(PY) --version)"
	@echo ""
	@echo "Checking dependencies..."
	@if [ ! -d "$(VENV_DIR)" ] && [ ! -d "node_modules" ]; then \
		echo "❌ Dependencies not installed. Run 'make dev' first."; \
		exit 1; \
	fi
	@echo "  ✅ Dependencies installed"
	@echo ""
	@echo "✅ Environment verification complete!"

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Cleanup & Rebuild Helpers                                                  │
# └─────────────────────────────────────────────────────────────────────────────┘

dev-clean:
	@echo "🧹 Cleaning project artifacts..."
	@rm -rf dist build .pytest_cache .mypy_cache __pycache__ *.pyc
	@find . -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true
	@find . -type d -name "*.egg-info" -exec rm -rf {} + 2>/dev/null || true
	@echo "✅ Clean complete"

dev-clean-all: dev-clean
	@echo "🗑️  Removing all dependencies..."
	@rm -rf $(VENV_DIR) node_modules
	@echo "✅ All dependencies removed"

dev-rebuild: dev-clean-all dev
	@echo "🔁 Development environment rebuilt"

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Compatibility & Legacy Aliases                                            │
# └─────────────────────────────────────────────────────────────────────────────┘

setup: dev
install: dev
clean: dev-clean
clean-all: dev-clean-all

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Support & Utility Targets                                                  │
# └─────────────────────────────────────────────────────────────────────────────┘

doctor:
	@echo "🩺 Generating support bundle..."
	@mkdir -p artifacts/support
	@echo "Python: $$($(PY) --version)" > artifacts/support/environment.txt
	@echo "Project: $(PROJECT_NAME)" >> artifacts/support/environment.txt
	@echo "✅ Support bundle written to artifacts/support/"

venv-activate:
	@if [ -d "$(VENV_DIR)" ]; then \
		echo "source $(VENV_DIR)/bin/activate"; \
	else \
		echo "ℹ️  No Python venv found. Create one with: $(PY) -m venv $(VENV_DIR)"; \
	fi

venv-run:
	@if [ -z "$(CMD)" ]; then echo "❌ Please provide CMD=..."; exit 1; fi
	@$(VENV_PY) -c "import os,sys; os.system(sys.argv[1])" "$(CMD)"
