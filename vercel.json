{
  "version": 2,
  "buildCommand": "make build-dashboard",
  "outputDirectory": "dist",

  "env": {
    "DASHBOARD_TITLE": "SmartHaus M365 Automation Empire"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/operations",
      "destination": "/index.html"
    },
    {
      "source": "/",
      "destination": "/sharepoint-intranet.html"
    },
    {
      "source": "/(.*)",
      "destination": "/sharepoint-intranet.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=60" }
      ]
    }
  ]
}
