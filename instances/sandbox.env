# Core
OPS_ADAPTER_ENV=sandbox

# Azure AD / Graph API Configuration
# NOTE: These are placeholder values - replace with your actual credentials
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# Graph API Configuration
GRAPH_TENANT_ID=your-tenant-id-here
GRAPH_CLIENT_ID=your-client-id-here
GRAPH_CLIENT_SECRET=your-client-secret-here

# Security / Identity
JWT_REQUIRED=false
JWT_ISSUER=http://localhost:8082
JWT_AUDIENCE=smarthaus-platform
JWKS_URL=http://host.docker.internal:8082/.well-known/jwks.json

# Policy engine (Enterprise OPA)
OPA_URL=http://host.docker.internal:8181
OPA_FAIL_OPEN=true

# Enterprise services
APPROVAL_SERVICE_URL=http://host.docker.internal:8083
AUDIT_SERVICE_URL=http://host.docker.internal:8084

# Optional integrations (dev defaults)
GRAPH_STUB_MODE=false
LOG_DIR=/app/logs
