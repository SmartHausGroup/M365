# Core
OPS_ADAPTER_ENV=sandbox
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_CERTIFICATE_PATH=/app/certs/azure_cert.pem

# Optional integrations
VERCEL_API_TOKEN=
TEAMS_APPROVALS_WEBHOOK=

# Audit/Logs
LOG_DIR=/app/logs
LA_WORKSPACE_ID=
LA_SHARED_KEY=

# Security (dev defaults)
# Require JWT on /actions when set true; in dev keep false
JWT_REQUIRED=false
# Accept HS256 tokens signed with the shared secret (dev only)
JWT_HS256_SECRET=
# Optionally validate issuer/audience when provided
JWT_ISSUER=
JWT_AUDIENCE=
# Policy engine behavior (fail closed in prod; open in dev)
OPA_FAIL_OPEN=true

# Graph stub mode: when true and Graph creds missing, return realistic stubs
GRAPH_STUB_MODE=true
