  "automation_workflows": {
    "project_status_updates": {
      "name": "Project Status Updates",
      "description": "Automatically update project status and notify stakeholders",
      "triggers": [
        "project_milestone_completed",
        "project_status_changed",
        "weekly_status_report"
      ],
      "actions": [
        "update_project_dashboard",
        "send_email_notifications",
        "update_sharepoint_lists",
        "create_teams_notifications"
      ]
    },
    "task_assignment_notifications": {
      "name": "Task Assignment Notifications",
      "description": "Notify team members when tasks are assigned",
      "triggers": [
        "task_assigned",
        "task_deadline_approaching",
        "task_completed"
      ],
      "actions": [
        "send_email_notification",
        "create_teams_message",
        "update_task_status",
        "log_activity"
      ]
    },
    "deadline_reminders": {
      "name": "Deadline Reminders",
      "description": "Send reminders for approaching deadlines",
      "triggers": [
        "deadline_approaching",
        "overdue_task",
        "milestone_due"
      ],
      "actions": [
        "send_reminder_email",
        "create_teams_alert",
        "escalate_to_manager",
        "update_project_status"
      ]
    }
  },
  "reporting_dashboards": {
    "project_overview": {
      "name": "Project Overview Dashboard",
      "description": "High-level view of all projects and their status",
      "metrics": [
        "total_projects",
        "active_projects",
        "completed_projects",
        "overall_progress",
        "resource_utilization"
      ],
      "visualizations": [
        "project_status_chart",
        "progress_timeline",
        "resource_allocation",
        "risk_heatmap"
      ]
    },
    "resource_utilization": {
      "name": "Resource Utilization Dashboard",
      "description": "Track team member workload and capacity",
      "metrics": [
        "team_member_workload",
        "project_allocation",
        "capacity_planning",
        "skill_gaps"
      ],
      "visualizations": [
        "workload_chart",
        "capacity_heatmap",
        "skill_matrix",
        "allocation_timeline"
      ]
    },
    "performance_metrics": {
      "name": "Performance Metrics Dashboard",
      "description": "Track project performance and KPIs",
      "metrics": [
        "on_time_delivery",
        "budget_variance",
        "quality_metrics",
        "customer_satisfaction"
      ],
      "visualizations": [
        "performance_trends",
        "kpi_scorecards",
        "variance_analysis",
        "quality_metrics"
      ]
    }
  },
  "integration_endpoints": {
    "github": {
      "enabled": true,
      "webhooks": [
        "pull_request_created",
        "issue_assigned",
        "milestone_completed",
        "release_created"
      ],
      "sync_fields": [
        "project_status",
        "task_completion",
        "milestone_progress",
        "team_activity"
      ]
    },
    "teams": {
      "enabled": true,
      "channels": [
        "project-updates",
        "team-coordination",
        "status-reports",
        "general-discussion"
      ],
      "integrations": [
        "project_status_bot",
        "task_assignment_bot",
        "deadline_reminder_bot"
      ]
    },
    "sharepoint": {
      "enabled": true,
      "libraries": [
        "project_documents",
        "project_templates",
        "meeting_minutes",
        "technical_documentation"
      ],
      "lists": [
        "project_tasks",
        "project_milestones",
        "project_risks",
        "project_resources"
      ]
    }
  }
}
