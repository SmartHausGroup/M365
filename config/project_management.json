{
  "platform": {
    "name": "SmartHaus M365 Project Management Platform",
    "version": "1.0.0",
    "description": "Complete project management platform using M365 E3 features",
    "owner": "phil@smarthausgroup.com",
    "tenant": "smarthausgroup.com"
  },
  "m365_services": {
    "sharepoint": {
      "enabled": true,
      "project_sites": true,
      "document_libraries": true,
      "project_calendars": true,
      "task_lists": true
    },
    "teams": {
      "enabled": true,
      "project_channels": true,
      "team_collaboration": true,
      "meeting_integration": true
    },
    "power_automate": {
      "enabled": true,
      "workflows": [
        "project_status_updates",
        "task_assignment_notifications",
        "deadline_reminders",
        "progress_reports",
        "team_sync_notifications"
      ]
    },
    "power_bi": {
      "enabled": true,
      "dashboards": [
        "project_overview",
        "resource_utilization",
        "timeline_tracking",
        "performance_metrics"
      ]
    },
    "project_online": {
      "enabled": true,
      "license": "P2",
      "features": [
        "project_planning",
        "resource_management",
        "portfolio_management",
        "reporting"
      ]
    }
  },
  "project_templates": {
    "website_development": {
      "name": "Website Development",
      "description": "Standard template for website development projects",
      "phases": [
        {
          "name": "Planning",
          "duration": "1-2 weeks",
          "tasks": [
            "Requirements gathering",
            "User research",
            "Technical architecture",
            "Project timeline"
          ]
        },
        {
          "name": "Design",
          "duration": "2-3 weeks",
          "tasks": [
            "UI/UX design",
            "Wireframes",
            "Prototypes",
            "Design system"
          ]
        },
        {
          "name": "Development",
          "duration": "4-8 weeks",
          "tasks": [
            "Frontend development",
            "Backend development",
            "API integration",
            "Testing"
          ]
        },
        {
          "name": "Testing",
          "duration": "1-2 weeks",
          "tasks": [
            "Unit testing",
            "Integration testing",
            "User acceptance testing",
            "Performance testing"
          ]
        },
        {
          "name": "Deployment",
          "duration": "1 week",
          "tasks": [
            "Production deployment",
            "Monitoring setup",
            "Documentation",
            "Training"
          ]
        }
      ]
    },
    "ai_research": {
      "name": "AI Research",
      "description": "Template for AI research and development projects",
      "phases": [
        {
          "name": "Research",
          "duration": "2-4 weeks",
          "tasks": [
            "Literature review",
            "State of the art analysis",
            "Research questions",
            "Methodology design"
          ]
        },
        {
          "name": "Prototyping",
          "duration": "3-6 weeks",
          "tasks": [
            "Concept development",
            "Initial prototypes",
            "Feasibility testing",
            "Iteration"
          ]
        },
        {
          "name": "Development",
          "duration": "6-12 weeks",
          "tasks": [
            "Core implementation",
            "Algorithm development",
            "Integration",
            "Testing"
          ]
        },
        {
          "name": "Validation",
          "duration": "2-4 weeks",
          "tasks": [
            "Performance evaluation",
            "Accuracy testing",
            "Benchmarking",
            "Validation studies"
          ]
        },
        {
          "name": "Documentation",
          "duration": "1-2 weeks",
          "tasks": [
            "Technical documentation",
            "Research papers",
            "User guides",
            "Knowledge transfer"
          ]
        }
      ]
    },
    "platform_integration": {
      "name": "Platform Integration",
      "description": "Template for platform integration projects",
      "phases": [
        {
          "name": "Analysis",
          "duration": "1-2 weeks",
          "tasks": [
            "Current state analysis",
            "Integration requirements",
            "API documentation review",
            "Technical feasibility"
          ]
        },
        {
          "name": "Design",
          "duration": "2-3 weeks",
          "tasks": [
            "Integration architecture",
            "Data flow design",
            "API design",
            "Security design"
          ]
        },
        {
          "name": "Implementation",
          "duration": "4-8 weeks",
          "tasks": [
            "Core integration",
            "API development",
            "Data mapping",
            "Testing"
          ]
        },
        {
          "name": "Testing",
          "duration": "2-3 weeks",
          "tasks": [
            "Integration testing",
            "End-to-end testing",
            "Performance testing",
            "Security testing"
          ]
        },
        {
          "name": "Deployment",
          "duration": "1-2 weeks",
          "tasks": [
            "Production deployment",
            "Monitoring",
            "Documentation",
            "Training"
          ]
        }
      ]
    }
  },
